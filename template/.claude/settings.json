{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(git:*)",
      "Bash(gh repo create:*)",
      "Bash(gh repo view:*)",
      "Bash(gh auth status:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pnpm:*)",
      "Bash(yarn:*)",
      "Bash(node:*)",
      "Bash(python:*)",
      "Bash(pip:*)",
      "Bash(mkdir:*)",
      "Bash(dir:*)",
      "Bash(type:*)",
      "Bash(copy:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(cp:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git clean:*)",
      "Bash(git reset --hard:*)",
      "Bash(rm -rf:*)",
      "Bash(gh repo delete:*)",
      "Bash(gh repo edit:*)",
      "Edit(.claude/settings.json)",
      "Write(.claude/settings.json)"
    ]
  }
}
